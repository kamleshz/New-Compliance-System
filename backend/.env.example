NODE_ENV=production
PORT=5000

# Use a MongoDB Atlas connection string in production.
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/compliance-system
# Optional alternative name used by some hosts like Render.
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/compliance-system

# Generate a long random value. Never commit the real secret.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# Optional one-time bootstrap account. Use a unique production password.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-unique-password
BOOTSTRAP_ADMIN_EMPLOYEE_CODE=EMP001
BOOTSTRAP_ADMIN_MOBILE=+910000000000

# Set these to the final Vercel production URL (without a trailing slash).
FRONTEND_URL=https://your-vercel-project.vercel.app
APP_BASE_URL=https://your-vercel-project.vercel.app
CORS_ORIGINS=https://your-vercel-project.vercel.app

# External CCP integration. The endpoint must be publicly reachable from Render.
CCP_API_BASE_URL=https://your-ccp-api.example.com
CCP_API_KEY=replace-with-your-ccp-api-key
CCP_USER_SYNC_PATH=/users/sync

# Optional email settings.
MAIL_USER=your-mailbox@example.com
MAIL_PASS=replace-with-an-app-password
MAIL_FROM=your-mailbox@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
